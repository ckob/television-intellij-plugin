<idea-plugin require-restart="true">
    <id>dev.ckob.television</id>
    <name>Television</name>
    <vendor url="https://github.com/ckob">ckob</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.ckob.television.TelevisionEditorProvider"/>
        <applicationService serviceImplementation="dev.ckob.television.TelevisionSettingsState"/>
        <applicationConfigurable parentId="tools" instance="dev.ckob.television.TelevisionSettingsConfigurable" id="dev.ckob.television.TelevisionSettingsConfigurable" displayName="Television"/>
        <postStartupActivity implementation="dev.ckob.television.TelevisionStartupActivity"/>
    </extensions>
</idea-plugin>
